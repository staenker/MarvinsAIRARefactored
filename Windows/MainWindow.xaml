<Window x:Class="MarvinsAIRARefactored.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windows="clr-namespace:MarvinsAIRARefactored.Windows"
        xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
        xmlns:components="clr-namespace:MarvinsAIRARefactored.Components"
        xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
        xmlns:viewers="clr-namespace:MarvinsAIRARefactored.Viewers"
        mc:Ignorable="d"
        Title="{Binding Localization[AppTitle]}"
        Icon="/Artwork/AppIcon/maira-universal.ico"
        MinWidth="550"
        MinHeight="350"
        Width="1100"
        Height="750"
        d:Height="Auto"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow"
        Closed="Window_Closed"
        WindowStartupLocation="CenterScreen"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged"
        ContentRendered="Window_ContentRendered"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        Background="#FF111111">

    <Window.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}"/>
    </Window.DataContext>

    <Grid x:Name="MainGrid">

        <Grid.LayoutTransform>
            <ScaleTransform x:Name="RootScaleTransform" ScaleX="{Binding Settings.AppUIScale}" ScaleY="{Binding Settings.AppUIScale}"/>
        </Grid.LayoutTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="Status_Border" Background="#FF111111" Padding="0,2,0,2" Tag="HideWhenGraphIsSoloed">

            <Grid HorizontalAlignment="Center">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" x:Name="Status_Panel1_Label" Content="" d:Content="Car Label" HorizontalAlignment="Center" Margin="20,0"/>
                <Label Grid.Column="1" x:Name="Status_Panel2_Label" Content="" d:Content="Track Label" HorizontalAlignment="Center" Margin="20,0"/>
                <Label Grid.Column="2" x:Name="Status_Panel3_Label" Content="" d:Content="Track Configuration Label" HorizontalAlignment="Center" Margin="20,0"/>
                <Label Grid.Column="3" x:Name="Status_Panel4_Label" Content="" d:Content="Dry" HorizontalAlignment="Center" Margin="20,0"/>

            </Grid>

        </Border>

        <Image Grid.Row="1" x:Name="Logo_Image" Source="/MarvinsAIRARefactored;component/Artwork/Misc/maira_logo_rotated.png" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10" RenderOptions.BitmapScalingMode="HighQuality" Visibility="Collapsed"/>

        <TabControl Grid.Row="1" x:Name="TabControl" TabStripPlacement="Left" SelectionChanged="TabControl_SelectionChanged">

            <TabItem x:Name="RacingWheel_TabItem" Header="{Binding Localization[RacingWheel]}" controls:TabItemPositionHelper.IsFirst="True">

                <StackPanel Background="#FF333333">

                    <StackPanel Margin="0,10,0,10">

                        <GroupBox Header="{Binding Localization[Device]}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <controls:MairaComboBox Grid.Column="0" Grid.ColumnSpan="3" x:Name="RacingWheel_SteeringDevice_ComboBox" Title="{Binding Localization[SteeringDevice]}" SelectedValue="{Binding Settings.RacingWheelSteeringDeviceGuid, Mode=TwoWay}" VerticalContentAlignment="Center"/>

                                <Grid Grid.Column="5" HorizontalAlignment="Center">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaMappableButton Grid.Column="0" x:Name="RacingWheel_Power_MairaMappableButton" Title="{Binding Localization[Power]}" BehindIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_power_led_black.png" ContextSwitches="{Binding Settings.RacingWheelEnableForceFeedbackContextSwitches}" ButtonMappings="{Binding Settings.RacingWheelEnableForceFeedbackButtonMappings}" Click="RacingWheel_Power_MairaMappableButton_Click"/>
                                    <controls:MairaMappableButton Grid.Column="2" x:Name="RacingWheel_Test_MairaMappableButton" Title="{Binding Localization[Test]}" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_vibrate.png" ButtonMappings="{Binding Settings.RacingWheelTestButtonMappings}" Click="RacingWheel_Test_MairaMappableButton_Click"/>
                                    <controls:MairaMappableButton Grid.Column="4" x:Name="RacingWheel_Reset_MairaMappableButton" Title="{Binding Localization[Reset]}" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_reset.png" ButtonMappings="{Binding Settings.RacingWheelResetButtonMappings}" Click="RacingWheel_Reset_MairaMappableButton_Click"/>

                                </Grid>

                            </Grid>

                        </GroupBox>

                        <GroupBox Header="{Binding Localization[OverallStrength]}">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[WheelForce]}" Value="{Binding Settings.RacingWheelWheelForce, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelWheelForceString}" SmallValueChangeStep="0.01" LargeValueChangeStep="1" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelWheelForceContextSwitches}" DefaultValue="5"/>
                                    <controls:MairaKnob Grid.Column="2" Title="{Binding Localization[Strength]}" Value="{Binding Settings.RacingWheelStrength, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelStrengthString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelStrengthContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelStrengthPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelStrengthMinusButtonMappings}" DefaultValue="0.1"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[MaxForce]}" Value="{Binding Settings.RacingWheelMaxForce, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelMaxForceString}" SmallValueChangeStep="0.01" LargeValueChangeStep="1" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelMaxForceContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelMaxForcePlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelMaxForceMinusButtonMappings}" DefaultValue="50"/>

                                </Grid>

                                <Grid Margin="0,20,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[AutoMargin]}" Value="{Binding Settings.RacingWheelAutoMargin, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelAutoMarginString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelAutoMarginContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelAutoMarginPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelAutoMarginMinusButtonMappings}" DefaultValue="0"/>

                                    <Grid Grid.Column="2" HorizontalAlignment="Center">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <controls:MairaMappableButton Grid.Column="0" x:Name="RacingWheel_Set_MairaMappableButton" Title="{Binding Localization[Set]}" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_magic.png" ButtonMappings="{Binding Settings.RacingWheelSetButtonMappings}" Click="RacingWheel_Set_MairaMappableButton_Click"/>
                                        <controls:MairaMappableButton Grid.Column="2" x:Name="RacingWheel_Clear_MairaMappableButton" Title="{Binding Localization[Clear]}" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_zero.png" ButtonMappings="{Binding Settings.RacingWheelClearButtonMappings}" Click="RacingWheel_Clear_MairaMappableButton_Click"/>

                                    </Grid>

                                    <Grid Grid.Column="4" VerticalAlignment="Center">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <Label Content="{Binding Localization[CurrentForce]}" HorizontalAlignment="Center" Padding="0"/>
                                            <Label x:Name="RacingWheel_CurrentForce_Label" Margin="0,20,0,10" Content="0.0 Nm" FontSize="32" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Fira Code" Foreground="White" Padding="0" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <Label Content="{Binding Localization[AutoForce]}" HorizontalAlignment="Center" Padding="0"/>
                                            <Label x:Name="RacingWheel_AutoForce_Label" Margin="0,20,0,10" Content="0.0 Nm" FontSize="32" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Fira Code" Foreground="White" Padding="0" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                    </Grid>

                                </Grid>

                            </StackPanel>

                        </GroupBox>

                        <GroupBox Header="{Binding Localization[Algorithm]}">

                            <StackPanel>

                                <Grid x:Name="RacingWheel_AlgorithmRowOne_Grid">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaComboBox Grid.Column="0" x:Name="RacingWheel_Algorithm_ComboBox" Title="{Binding Localization[Algorithm]}" SelectedValue="{Binding Settings.RacingWheelAlgorithm, Mode=TwoWay}" VerticalContentAlignment="Center" ContextSwitches="{Binding Settings.RacingWheelAlgorithmContextSwitches}"/>

                                    <controls:MairaKnob Grid.Column="2" x:Name="RacingWheel_DetailBoost_KnobControl" Title="{Binding Localization[DetailBoost]}" Value="{Binding Settings.RacingWheelDetailBoost, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelDetailBoostString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelDetailBoostContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelDetailBoostPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelDetailBoostMinusButtonMappings}" DefaultValue="0"/>
                                    <controls:MairaKnob Grid.Column="4" x:Name="RacingWheel_DetailBoostBias_KnobControl" Title="{Binding Localization[DetailBoostBias]}" Value="{Binding Settings.RacingWheelDetailBoostBias, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelDetailBoostBiasString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.05" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelDetailBoostBiasContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelDetailBoostBiasPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelDetailBoostBiasMinusButtonMappings}" DefaultValue="0.1"/>

                                    <controls:MairaKnob Grid.Column="2" x:Name="RacingWheel_DeltaLimit_KnobControl" Title="{Binding Localization[DeltaLimit]}" Value="{Binding Settings.RacingWheelDeltaLimit, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelDeltaLimitString}" SmallValueChangeStep="1" LargeValueChangeStep="10" RotationMultiplier="0.01" ContextSwitches="{Binding Settings.RacingWheelDeltaLimitContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelDeltaLimitPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelDeltaLimitMinusButtonMappings}" DefaultValue="500"/>
                                    <controls:MairaKnob Grid.Column="4" x:Name="RacingWheel_DeltaLimiterBias_KnobControl" Title="{Binding Localization[DeltaLimiterBias]}" Value="{Binding Settings.RacingWheelDeltaLimiterBias, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelDeltaLimiterBiasString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.05" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelDeltaLimiterBiasContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelDeltaLimiterBiasPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelDeltaLimiterBiasMinusButtonMappings}" DefaultValue="0.2"/>

                                    <controls:MairaKnob Grid.Column="2" x:Name="RacingWheel_SlewCompressionThreshold" Title="{Binding Localization[SlewCompressionThreshold]}" Value="{Binding Settings.RacingWheelSlewCompressionThreshold, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelSlewCompressionThresholdString}" SmallValueChangeStep="0.1" LargeValueChangeStep="1" RotationMultiplier="0.1" ContextSwitches="{Binding Settings.RacingWheelSlewCompressionThresholdContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelSlewCompressionThresholdPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelSlewCompressionThresholdMinusButtonMappings}" DefaultValue="2"/>
                                    <controls:MairaKnob Grid.Column="4" x:Name="RacingWheel_SlewCompressionRate" Title="{Binding Localization[SlewCompressionRate]}" Value="{Binding Settings.RacingWheelSlewCompressionRate, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelSlewCompressionRateString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelSlewCompressionRateContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelSlewCompressionRatePlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelSlewCompressionRateMinusButtonMappings}" DefaultValue="0.65"/>

                                </Grid>

                                <Grid Margin="0,20,0,0" x:Name="RacingWheel_AlgorithmRowTwo_Grid">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="2" x:Name="RacingWheel_TotalCompressionThreshold" Title="{Binding Localization[TotalCompressionThreshold]}" Value="{Binding Settings.RacingWheelTotalCompressionThreshold, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelTotalCompressionThresholdString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelTotalCompressionThresholdContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelTotalCompressionThresholdPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelTotalCompressionThresholdMinusButtonMappings}" DefaultValue="0.65"/>
                                    <controls:MairaKnob Grid.Column="4" x:Name="RacingWheel_TotalCompressionRate" Title="{Binding Localization[TotalCompressionRate]}" Value="{Binding Settings.RacingWheelTotalCompressionRate, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelTotalCompressionRateString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelTotalCompressionRateContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelTotalCompressionRatePlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelTotalCompressionRateMinusButtonMappings}" DefaultValue="0.75"/>

                                </Grid>

                            </StackPanel>

                        </GroupBox>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[Output]}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[Minimum]}" Value="{Binding Settings.RacingWheelOutputMinimum, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelOutputMinimumString}" SmallValueChangeStep="0.0001" LargeValueChangeStep="0.001" RotationMultiplier="100" ContextSwitches="{Binding Settings.RacingWheelOutputMinimumContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelOutputMinimumPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelOutputMinimumMinusButtonMappings}" DefaultValue="0"/>
                                    <controls:MairaKnob Grid.Column="2" Title="{Binding Localization[Maximum]}" Value="{Binding Settings.RacingWheelOutputMaximum, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelOutputMaximumString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelOutputMaximumContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelOutputMaximumPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelOutputMaximumMinusButtonMappings}" DefaultValue="1"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[Curve]}" Value="{Binding Settings.RacingWheelOutputCurve, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelOutputCurveString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelOutputCurveContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelOutputCurvePlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelOutputCurveMinusButtonMappings}" ShowCurve="True" DefaultValue="0"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[Preview]}">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderThickness="2" BorderBrush="#FFF" Background="#80000000" CornerRadius="5" Padding="0,0,0,6">
                                        <ScrollViewer x:Name="RacingWheel_Preview_ScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=GroupBox}}" PreviewMouseWheel="RacingWheel_Preview_ScrollViewer_PreviewMouseWheel">
                                            <Image x:Name="RacingWheel_AlgorithmPreview_Image" Height="301" Width="3840" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </ScrollViewer>
                                    </Border>

                                    <controls:MairaComboBox Grid.Row="2" x:Name="RacingWheel_PreviewRecordings_ComboBox" SelectedValue="{Binding Settings.RacingWheelSelectedRecording, Mode=TwoWay}" VerticalContentAlignment="Center"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[WheelLFE]}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaComboBox Grid.Column="0" Grid.ColumnSpan="3" x:Name="RacingWheel_LFERecordingDevice_ComboBox" Title="{Binding Localization[LFERecordingDevice]}" SelectedValue="{Binding Settings.RacingWheelLFERecordingDeviceGuid, Mode=TwoWay}" VerticalContentAlignment="Center"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[Strength]}" Value="{Binding Settings.RacingWheelLFEStrength, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelLFEStrengthString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelLFEStrengthContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelLFEStrengthPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelLFEStrengthMinusButtonMappings}" DefaultValue="0.05"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[CrashProtection]}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[GForce]}" Value="{Binding Settings.RacingWheelCrashProtectionGForce, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCrashProtectionGForceString}" SmallValueChangeStep="0.01" LargeValueChangeStep="0.5" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelCrashProtectionGForceContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCrashProtectionGForcePlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCrashProtectionGForceMinusButtonMappings}" DefaultValue="8"/>
                                    <controls:MairaKnob Grid.Column="2" Title="{Binding Localization[Duration]}" Value="{Binding Settings.RacingWheelCrashProtectionDuration, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCrashProtectionDurationString}" SmallValueChangeStep="0.01" LargeValueChangeStep="0.5" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelCrashProtectionDurationContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCrashProtectionDurationPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCrashProtectionDurationMinusButtonMappings}" DefaultValue="5"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[ForceReduction]}" Value="{Binding Settings.RacingWheelCrashProtectionForceReduction, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCrashProtectionForceReductionString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelCrashProtectionForceReductionContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCrashProtectionForceReductionPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCrashProtectionForceReductionMinusButtonMappings}" DefaultValue="0.95"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox x:Name="RacingWheel_CurbProtection_GroupBox" Header="{Binding Localization[CurbProtection]}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[ShockVelocity]}" Value="{Binding Settings.RacingWheelCurbProtectionShockVelocity, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCurbProtectionShockVelocityString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelCurbProtectionShockVelocityContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCurbProtectionShockVelocityPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCurbProtectionShockVelocityMinusButtonMappings}" DefaultValue="0.5"/>
                                    <controls:MairaKnob Grid.Column="2" Title="{Binding Localization[Duration]}" Value="{Binding Settings.RacingWheelCurbProtectionDuration, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCurbProtectionDurationString}" SmallValueChangeStep="0.01" LargeValueChangeStep="0.1" RotationMultiplier="1" ContextSwitches="{Binding Settings.RacingWheelCurbProtectionDurationContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCurbProtectionDurationPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCurbProtectionDurationMinusButtonMappings}" DefaultValue="0.1"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[ForceReduction]}" Value="{Binding Settings.RacingWheelCurbProtectionForceReduction, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelCurbProtectionForceReductionString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.01" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelCurbProtectionForceReductionContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelCurbProtectionForceReductionPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelCurbProtectionForceReductionMinusButtonMappings}" DefaultValue="0.75"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[ParkedEffects]}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:MairaKnob Grid.Column="0" Title="{Binding Localization[ForceFeedbackStrength]}" Value="{Binding Settings.RacingWheelParkedStrength, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelParkedStrengthString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.05" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelParkedStrengthContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelParkedStrengthPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelParkedStrengthMinusButtonMappings}" DefaultValue="0.15"/>
                                    <controls:MairaKnob Grid.Column="2" Title="{Binding Localization[ParkedFriction]}" Value="{Binding Settings.RacingWheelParkedFriction, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelParkedFrictionString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.05" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelParkedFrictionContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelParkedFrictionPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelParkedFrictionMinusButtonMappings}" DefaultValue="0"/>
                                    <controls:MairaKnob Grid.Column="4" Title="{Binding Localization[ParkedWheelCenteringStrength]}" Value="{Binding Settings.RacingWheelParkedWheelCenteringStrength, Mode=TwoWay}" ValueString="{Binding Settings.RacingWheelParkedWheelCenteringStrengthString}" SmallValueChangeStep="0.001" LargeValueChangeStep="0.05" RotationMultiplier="10" ContextSwitches="{Binding Settings.RacingWheelParkedWheelCenteringStrengthContextSwitches}" PlusButtonMappings="{Binding Settings.RacingWheelParkedWheelCenteringStrengthPlusButtonMappings}" MinusButtonMappings="{Binding Settings.RacingWheelParkedWheelCenteringStrengthMinusButtonMappings}" DefaultValue="0.25"/>

                                </Grid>

                            </GroupBox>

                        </Grid>

                        <Grid Tag="Complex">

                            <GroupBox Header="{Binding Localization[OtherFeatures]}">

                                <Grid>

