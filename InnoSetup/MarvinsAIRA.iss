Name: "{userdocs}\MarvinsAIRA Refactored\Recordings"
Name: "{userdocs}\MarvinsAIRA Refactored\Calibration"
Name: "{userdocs}\MarvinsAIRA Refactored\STT"
Name: "{userdocs}\MarvinsAIRA Refactored\SimHub"

[Files]
