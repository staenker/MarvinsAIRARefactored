<UserControl x:Class="MarvinsAIRARefactored.Pages.HelpPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[Documentation_UC]}">

                <StackPanel>

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding Localization[DocumentationText], Mode=OneWay}"
                               Margin="0,0,0,20" />

                    <Border BorderBrush="#666"
                            BorderThickness="1"
                            CornerRadius="5"
                            HorizontalAlignment="Left">

                        <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                                   Padding="15,5">

                        <Hyperlink NavigateUri="https://mairapp.com/home/documentation/"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#fff"
                                   TextDecorations="None">

                            <InlineUIContainer BaselineAlignment="Center">
                        
                                <Image Source="/MarvinsAIRARefactored;component/Artwork/Misc/world-wide-web.png"
                                       Height="24"
                                       Margin="0,0,5,0" />
                        
                            </InlineUIContainer>

                            <Run Text="{Binding Localization[DocumentationWebsite], Mode=OneWay}" />

                        </Hyperlink>

                        </TextBlock>

                    </Border>

                </StackPanel>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[Discord_UC]}">

            <StackPanel>

                <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                           TextWrapping="Wrap"
                           Text="{Binding Localization[DiscordText], Mode=OneWay}"
                           Margin="0,0,0,20" />

                <Border BorderBrush="#666"
                        BorderThickness="1"
                        CornerRadius="5"
                        HorizontalAlignment="Left">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Padding="15,5">

                        <Hyperlink NavigateUri="https://discord.gg/3eJhe8Tvq2"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#fff"
                                   TextDecorations="None">

                            <InlineUIContainer BaselineAlignment="Center">
                        
                                <Image Source="/MarvinsAIRARefactored;component/Artwork/Misc/discord-logo.png"
                                       Height="24"
                                       Margin="0,0,5,0" />
                        
                            </InlineUIContainer>

                            <Run Text="{Binding Localization[DiscordServer], Mode=OneWay}" />

                        </Hyperlink>

                    </TextBlock>

                </Border>

            </StackPanel>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[Forums_UC]}">

            <StackPanel>

                <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                           TextWrapping="Wrap"
                           Text="{Binding Localization[ForumsText], Mode=OneWay}"
                           Margin="0,0,0,20" />

                <Border BorderBrush="#666"
                        BorderThickness="1"
                        CornerRadius="5"
                        HorizontalAlignment="Left">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Padding="15,5">

                        <Hyperlink NavigateUri="https://forums.iracing.com/discussion/72467/marvins-awesome-iracing-app#latest"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#fff"
                                   TextDecorations="None">

                            <InlineUIContainer BaselineAlignment="Center">
                        
                                <Image Source="/MarvinsAIRARefactored;component/Artwork/Misc/iracing-logo.png"
                                       Height="24"
                                       Margin="0,0,5,0" />
                        
                            </InlineUIContainer>

                            <Run Text="{Binding Localization[iRacingForums], Mode=OneWay}" />

                        </Hyperlink>

                    </TextBlock>

                </Border>

            </StackPanel>

        </controls:MairaGroupBox>

    </StackPanel>

</UserControl>
