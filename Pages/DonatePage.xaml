             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[SuperDonors_UC]}"
                                SubLabel="❤️❤️❤️">

            <StackPanel>

                <UniformGrid Columns="3">

                    <UniformGrid.Resources>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource MairaTextBlockStyle}">
                        </Style>
                    </UniformGrid.Resources>

                    <TextBlock Text="Bruno Cerdeira Santos" />
