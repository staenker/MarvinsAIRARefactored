                    <TextBlock Text="Travis Boudreaux" />

                </UniformGrid>

                <Grid Margin="0,40,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1"
                            Background="#444"
                            Padding="20"
                            CornerRadius="10">

                        <StackPanel>

                            <TextBlock TextWrapping="Wrap"
                                       Style="{StaticResource MairaTextBlockStyle}"
                                       FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow Italic"
                                       Text="{Binding Localization[DonationsText], Mode=OneWay}" />

                            <TextBlock TextWrapping="Wrap"
                                       Style="{StaticResource MairaTextBlockStyle}"
                                       FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow Italic"
                                       Text="- Marvin"
                                       HorizontalAlignment="Right" />

                        </StackPanel>

                    </Border>

                </Grid>

                <TextBlock Margin="0,10,0,10"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="{Binding Localization[ReadyToDonate], Mode=OneWay}"
                           HorizontalAlignment="Center" />

                <Border BorderBrush="#666"
                        BorderThickness="1"
                        CornerRadius="5"
                        HorizontalAlignment="Center">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Padding="15,5">

                <Hyperlink NavigateUri="https://buymeacoffee.com/marvinherbold"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#ff5b2e"
                           TextDecorations="None">

                    <InlineUIContainer BaselineAlignment="Center">
                        
                        <Image Source="/MarvinsAIRARefactored;component/Artwork/Misc/buy-me-a-coffee-logo.png"
                                Height="24"
                                Margin="0,0,5,0" />
                        
                    </InlineUIContainer>

                    <Run Text="{Binding Localization[BuyMeACoffee], Mode=OneWay}" />

                </Hyperlink>

                    </TextBlock>

                </Border>

            </StackPanel>

