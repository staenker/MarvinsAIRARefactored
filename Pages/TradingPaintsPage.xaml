<UserControl x:Class="MarvinsAIRARefactored.Pages.TradingPaintsPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[Settings_UC]}"
                                HelpTopic="advanced/trading-paints/#settings">

            <StackPanel>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <controls:MairaSwitch Grid.Row="0"
                                          Grid.Column="0"
                                          IsOn="{Binding Settings.TradingPaintsEnabled, Mode=TwoWay}"
                                          Label="{Binding Localization[Enabled]}"
                                          LabelPosition="Top" />

                    <Image Grid.Row="0"
                           Grid.Column="5"
                           Height="50"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/MarvinsAIRARefactored;component/Artwork/Misc/trading-paints.png" />

                    <controls:MairaTextBox Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="5"
                                           Label="{Binding Localization[IRacingPaintFolder]}"
                                           Value="{Binding Settings.TradingPaintsFolder, Mode=TwoWay}" />

                </Grid>

                <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="#888"
                           TextWrapping="Wrap"
                           Text="{Binding Localization[TradingPaintsDisclaimer]}"
                           Margin="0,60,0,0" />

            </StackPanel>

        </controls:MairaGroupBox>

    </StackPanel>

</UserControl>
