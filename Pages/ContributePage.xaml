<UserControl x:Class="MarvinsAIRARefactored.Pages.ContributePage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[CodeContributions_UC]}">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource MairaTextBlockStyle}"
                               Foreground="#ff5b2e">
                                
                    <Run Text="{Binding Localization[Contributors], Mode=OneWay}" />
                
                    ❤️❤️❤️

                    </TextBlock>

                    <UniformGrid Columns="1"
                                 Margin="0,10,0,0">

                        <UniformGrid.Resources>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource MairaTextBlockStyle}">
                            </Style>
                        </UniformGrid.Resources>

                        <TextBlock Text="Alan Le" />
                        <TextBlock Text="Matthew Brittle" />
                        <TextBlock Text="Scott @ BoxBoxDesign" />

                    </UniformGrid>

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding Localization[CodeContributionsText], Mode=OneWay}"
                               Margin="0,0,0,20" />

                    <Border BorderBrush="#666"
                            BorderThickness="1"
                            CornerRadius="5"
                            HorizontalAlignment="Left">

                        <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                                   Padding="15,5">

                        <Hyperlink NavigateUri="https://github.com/mherbold/MarvinsAIRARefactored"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#fff"
                                   TextDecorations="None">

                            <InlineUIContainer BaselineAlignment="Center">
                        
                                <Image Source="/MarvinsAIRARefactored;component/Artwork/Misc/github-logo.png"
                                       Height="24"
                                       Margin="0,0,5,0" />
                        
                            </InlineUIContainer>

                            <Run Text="{Binding Localization[GitHubRepository], Mode=OneWay}" />

                        </Hyperlink>

                        </TextBlock>

                    </Border>

                </StackPanel>

            </Grid>

        </controls:MairaGroupBox>

