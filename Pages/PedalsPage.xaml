                                          Grid.Column="6"
                                          Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/vibrate.png"
                                          ButtonMappings="{Binding Settings.PedalsClutchTest3ButtonMappings}"
                                          Click="ClutchTest3_MairaMappableButton_Click"
                                          IsSmall="True" />

        </Grid>

