<UserControl x:Class="MarvinsAIRARefactored.Pages.PedalsPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupHeader Label="{Binding Localization[Device_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <controls:MairaSwitch Grid.Column="0"
                                  IsOn="{Binding Settings.PedalsEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Center" />

            <TextBlock x:Name="Device_Label"
                       Grid.Column="2"
                       Style="{StaticResource MairaTextBlockStyle}"
                       FontSize="30"
                       Text="{Binding Localization[PedalsNone]}"
                       VerticalAlignment="Center" />

            <Image Grid.Column="4"
                   Source="/MarvinsAIRARefactored;component/Artwork/Misc/simagic-logo.png"
                   Height="32"
                   VerticalAlignment="Center" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[Frequency_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[Minimum]}"
                                Value="{Binding Settings.PedalsMinimumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsMinimumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.PedalsMinimumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsMinimumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsMinimumFrequencyMinusButtonMappings}"
                                DefaultValue="15" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Maximum]}"
                                Value="{Binding Settings.PedalsMaximumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsMaximumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.PedalsMaximumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsMaximumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsMaximumFrequencyMinusButtonMappings}"
                                DefaultValue="50" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.PedalsFrequencyCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsFrequencyCurveString}"
                                StepSize="0.05"
                                ContextSwitches="{Binding Settings.PedalsFrequencyCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsFrequencyCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsFrequencyCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0.25" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[Amplitude_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[Minimum]}"
                                Value="{Binding Settings.PedalsMinimumAmplitude, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsMinimumAmplitudeString}"
                                StepSize="0.05"
                                ContextSwitches="{Binding Settings.PedalsMinimumAmplitudeContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsMinimumAmplitudePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsMinimumAmplitudeMinusButtonMappings}"
                                DefaultValue="0" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Maximum]}"
                                Value="{Binding Settings.PedalsMaximumAmplitude, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsMaximumAmplitudeString}"
                                StepSize="0.05"
                                ContextSwitches="{Binding Settings.PedalsMaximumAmplitudeContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsMaximumAmplitudePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsMaximumAmplitudeMinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.PedalsAmplitudeCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsAmplitudeCurveString}"
                                StepSize="0.05"
                                ContextSwitches="{Binding Settings.PedalsAmplitudeCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsAmplitudeCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsAmplitudeCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0" />

        </Grid>

