            <TextBlock Grid.Row="0"
                       Grid.Column="6"
                       Style="{StaticResource MairaTextBlockStyle}"
                       Text="{Binding Localization[Test]}"
                       HorizontalAlignment="Center" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Style="{StaticResource MairaTextBlockStyle}"
                       Text="1"
                       FontSize="30" />

            <controls:MairaComboBox x:Name="ClutchEffect1_MairaComboBox"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    SelectedValue="{Binding Settings.PedalsClutchEffect1, Mode=TwoWay}"
                                    ContextSwitches="{Binding Settings.PedalsClutchEffect1ContextSwitches}" />

            <controls:MairaKnob Grid.Row="1"
                                Grid.Column="4"
                                Value="{Binding Settings.PedalsClutchStrength1, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsClutchStrength1String}"
                                StepSize="0.05"
                                ContextSwitches="{Binding Settings.PedalsClutchStrength1ContextSwitches}"
                                PlusButtonMappings="{Binding Settings.PedalsClutchStrength1PlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsClutchStrength1MinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaMappableButton x:Name="ClutchTest1_MairaMappableButton"
                                          Grid.Row="1"
                                          Grid.Column="6"
                                          Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/vibrate.png"
                                          ButtonMappings="{Binding Settings.PedalsClutchTest1ButtonMappings}"
                                          Click="ClutchTest1_MairaMappableButton_Click"
                                          IsSmall="True" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Style="{StaticResource MairaTextBlockStyle}"
                       Text="2"
                       FontSize="30" />

            <controls:MairaComboBox x:Name="ClutchEffect2_MairaComboBox"
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    SelectedValue="{Binding Settings.PedalsClutchEffect2, Mode=TwoWay}" />

            <controls:MairaKnob Grid.Row="3"
                                Grid.Column="4"
                                Value="{Binding Settings.PedalsClutchStrength2, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsClutchStrength2String}"
                                StepSize="0.05"
                                PlusButtonMappings="{Binding Settings.PedalsClutchStrength2PlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsClutchStrength2MinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaMappableButton x:Name="ClutchTest2_MairaMappableButton"
                                          Grid.Row="3"
                                          Grid.Column="6"
                                          Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/vibrate.png"
                                          ButtonMappings="{Binding Settings.PedalsClutchTest2ButtonMappings}"
                                          Click="ClutchTest2_MairaMappableButton_Click"
                                          IsSmall="True" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Style="{StaticResource MairaTextBlockStyle}"
                       Text="3"
                       FontSize="30" />

            <controls:MairaComboBox x:Name="ClutchEffect3_MairaComboBox"
