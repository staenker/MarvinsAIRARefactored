                                    SelectedValue="{Binding Settings.PedalsClutchEffect3, Mode=TwoWay}" />

            <controls:MairaKnob Grid.Row="5"
                                Grid.Column="4"
                                Value="{Binding Settings.PedalsClutchStrength3, Mode=TwoWay}"
                                ValueString="{Binding Settings.PedalsClutchStrength3String}"
                                StepSize="0.05"
                                PlusButtonMappings="{Binding Settings.PedalsClutchStrength3PlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.PedalsClutchStrength3MinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaMappableButton x:Name="ClutchTest3_MairaMappableButton"
