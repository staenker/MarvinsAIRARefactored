                                    ValueString="{Binding Settings.SoundsABSEngagedVolumeString}"
                                    StepSize="0.01"
                                    PlusButtonMappings="{Binding Settings.SoundsABSEngagedVolumePlusButtonMappings}"
                                    MinusButtonMappings="{Binding Settings.SoundsABSEngagedVolumeMinusButtonMappings}"
                                    DefaultValue="0.75" />

                <controls:MairaKnob Grid.Column="4"
                                    Label="{Binding Localization[FrequencyRatio]}"
