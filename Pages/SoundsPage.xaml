<UserControl x:Class="MarvinsAIRARefactored.Pages.SoundsPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[Master_UC]}"
                                HelpTopic="advanced/sounds/#master">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.SoundsMasterEnabled, Mode=TwoWay}"
                                      Label="{Binding Localization[Enabled]}"
                                      LabelPosition="Top" />

                <controls:MairaKnob Grid.Column="2"
                                    Label="{Binding Localization[Volume]}"
                                    Value="{Binding Settings.SoundsMasterVolume, Mode=TwoWay}"
                                    ValueString="{Binding Settings.SoundsMasterVolumeString}"
                                    StepSize="0.01"
                                    PlusButtonMappings="{Binding Settings.SoundsMasterVolumePlusButtonMappings}"
                                    MinusButtonMappings="{Binding Settings.SoundsMasterVolumeMinusButtonMappings}"
                                    DefaultValue="0.75" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[Click_UC]}"
                                HelpTopic="advanced/sounds/#click">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.SoundsClickEnabled, Mode=TwoWay}"
                                      Label="{Binding Localization[Enabled]}"
                                      LabelPosition="Top" />

                <controls:MairaKnob Grid.Column="2"
                                    Label="{Binding Localization[Volume]}"
                                    Value="{Binding Settings.SoundsClickVolume, Mode=TwoWay}"
                                    ValueString="{Binding Settings.SoundsClickVolumeString}"
                                    StepSize="0.01"
                                    PlusButtonMappings="{Binding Settings.SoundsClickVolumePlusButtonMappings}"
                                    MinusButtonMappings="{Binding Settings.SoundsClickVolumeMinusButtonMappings}"
                                    DefaultValue="0.75" />

                <controls:MairaKnob Grid.Column="4"
                                    Label="{Binding Localization[FrequencyRatio]}"
                                    Value="{Binding Settings.SoundsClickFrequencyRatio, Mode=TwoWay}"
                                    ValueString="{Binding Settings.SoundsClickFrequencyRatioString}"
                                    StepSize="0.01"
                                    PlusButtonMappings="{Binding Settings.SoundsClickFrequencyRatioPlusButtonMappings}"
                                    MinusButtonMappings="{Binding Settings.SoundsClickFrequencyRatioMinusButtonMappings}"
                                    DefaultValue="1" />

                <controls:MairaButton Grid.Column="10"
                                      Label="{Binding Localization[Test]}"
                                      Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/vibrate.png"
                                      Click="Click_Test_MairaButton_Click"
                                      IsSmall="True" />

            </Grid>

        </controls:MairaGroupBox>

