                                    ValueString="{Binding Settings.SoundsABSEngagedFrequencyRatioString}"
                                    StepSize="0.01"
                                    PlusButtonMappings="{Binding Settings.SoundsABSEngagedFrequencyRatioPlusButtonMappings}"
                                    MinusButtonMappings="{Binding Settings.SoundsABSEngagedFrequencyRatioMinusButtonMappings}"
                                    DefaultValue="1" />

                <controls:MairaSwitch Grid.Column="8"
                                      IsOn="{Binding Settings.SoundsABSEngagedFadeWithBrake, Mode=TwoWay}"
                                      Label="{Binding Localization[Fade]}"
                                      LabelPosition="Top" />

                <controls:MairaButton Grid.Column="10"
                                      Label="{Binding Localization[Test]}"
                                      Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/vibrate.png"
                                      Click="ABSEngaged_Test_MairaButton_Click"
                                      IsSmall="True" />

            </Grid>

        </controls:MairaGroupBox>

