<Application x:Class="MarvinsAIRARefactored.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MarvinsAIRARefactored"
             xmlns:classes="clr-namespace:MarvinsAIRARefactored.Classes"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2"
             Startup="App_Startup"
             Exit="App_Exit"
             ShutdownMode="OnMainWindowClose">

    <Application.Resources>

        <ResourceDictionary>

            <!-- Help Icon -->

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/SharedHelpIcon.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <!-- Colors -->

            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                             Color="#313131" />
            <SolidColorBrush x:Key="Background.Default"
                             Color="#313131" />
            <SolidColorBrush x:Key="Foreground.Normal"
                             Color="#979797" />

            <!-- Window -->

            <Style TargetType="{x:Type Window}">

                <Setter Property="Background"
                        Value="{StaticResource Background.Default}" />

            </Style>

            <!-- TextBlock -->

            <Style TargetType="{x:Type TextBlock}"
                   x:Key="MairaTextBlockStyle">

                <Setter Property="FontFamily"
                        Value="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" />
                <Setter Property="Typography.NumeralAlignment"
                        Value="Tabular" />
                <Setter Property="Typography.NumeralStyle"
                        Value="Lining" />
                <Setter Property="Typography.SlashedZero"
                        Value="True" />
                <Setter Property="FontSize"
                        Value="20" />
                <Setter Property="Foreground"
                        Value="#ffffff" />

            </Style>

            <!-- ToggleButton -->

            <Style TargetType="{x:Type ToggleButton}"
                   x:Key="MairaToggleButtonStyle">

                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderBrush"
                        Value="#444" />
                <Setter Property="BorderThickness"
                        Value="0,0,0,2" />
                <Setter Property="FontSize"
                        Value="30" />
                <Setter Property="FontFamily"
                        Value="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" />

                <Setter Property="Template">

                    <Setter.Value>

                        <ControlTemplate TargetType="ToggleButton">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="0"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">

                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      RecognizesAccessKey="True"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                      ContentStringFormat="{TemplateBinding ContentStringFormat}" />

                                </Border>

                                <Image x:Name="Glyph"
                                       Grid.Column="2"
                                       Source="/MarvinsAIRARefactored;component/Artwork/Buttons/combo-box-default.png"
                                       Width="32"
                                       Height="32"
                                       HorizontalAlignment="Right"
                                       RenderOptions.BitmapScalingMode="HighQuality" />

                            </Grid>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="BorderBrush"
                                            Value="#666666" />
                                    <Setter TargetName="Glyph"
                                            Property="Source"
                                            Value="pack://application:,,,/MarvinsAIRARefactored;component/Artwork/Buttons/combo-box-hover.png" />
                                </Trigger>

                                <Trigger Property="IsChecked"
                                         Value="True">
                                    <Setter Property="BorderBrush"
                                            Value="Transparent" />
                                    <Setter TargetName="Glyph"
                                            Property="Source"
                                            Value="pack://application:,,,/MarvinsAIRARefactored;component/Artwork/Buttons/combo-box-checked.png" />
                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>

                    </Setter.Value>

                </Setter>

            </Style>

            <!-- ComboBoxItem -->

            <Style TargetType="{x:Type ComboBoxItem}">

                <Setter Property="Foreground"
                        Value="#dddddd" />
                <Setter Property="Padding"
                        Value="10,5" />
                <Setter Property="FontSize"
                        Value="20" />
                <Setter Property="Cursor"
                        Value="Hand" />

                <Setter Property="Template">

                    <Setter.Value>

                        <ControlTemplate TargetType="ComboBoxItem">

                            <Grid>

                                <Border BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="5"
                                        Margin="5,0">

                                    <Border.Style>

                                        <Style TargetType="Border">

                                            <Setter Property="BorderBrush"
                                                    Value="Transparent" />

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#10ffffff" />
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>

                                    </Border.Style>

                                </Border>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="1"
                                            BorderThickness="2,0,0,0"
                                            Margin="0,10">

                                        <Border.Style>

                                            <Style TargetType="Border">

                                                <Setter Property="BorderBrush"
                                                        Value="Transparent" />

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                 Value="True">
                                                        <Setter Property="BorderBrush"
                                                                Value="#666" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                 Value="True">
                                                        <Setter Property="BorderBrush"
                                                                Value="#ff5b2e" />
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </Border.Style>

                                    </Border>

                                    <TextBlock Grid.Column="3"
                                               Style="{StaticResource MairaTextBlockStyle}"
                                               Foreground="#ddd"
                                               Padding="0,5">

                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />

                                    </TextBlock>

                                </Grid>

                            </Grid>

                        </ControlTemplate>

                    </Setter.Value>

                </Setter>

            </Style>

            <!-- ComboBox -->

            <Style TargetType="{x:Type ComboBox}">

                <EventSetter Event="PreviewMouseWheel"
                             Handler="ComboBox_PreviewMouseWheel" />

                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                        Value="Auto" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                        Value="Auto" />
                <Setter Property="ScrollViewer.CanContentScroll"
                        Value="True" />
                <Setter Property="DisplayMemberPath"
                        Value="Value" />
                <Setter Property="SelectedValuePath"
                        Value="Key" />
                <Setter Property="Cursor"
                        Value="Hand" />

                <Setter Property="Template">

                    <Setter.Value>

                        <ControlTemplate TargetType="ComboBox">

                            <Grid>

                                <ToggleButton Name="ToggleButton"
                                              Style="{StaticResource MairaToggleButtonStyle}"
                                              Focusable="False"
                                              Foreground="{TemplateBinding Foreground}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">

                                    <Grid ClipToBounds="True">
                                        <TextBlock Text="{Binding SelectedItem.Value, RelativeSource={RelativeSource TemplatedParent}}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                </ToggleButton>

                                <Popup Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False">

                                    <Border Background="#222"
                                            Padding="0,5"
                                            BorderBrush="#444"
                                            BorderThickness="2"
                                            SnapsToDevicePixels="True">

                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>

                                    </Border>

                                </Popup>

                            </Grid>

                        </ControlTemplate>

                    </Setter.Value>

                </Setter>

            </Style>

            <!-- Thumb -->

            <Style TargetType="{x:Type Thumb}"
                   x:Key="ScrollBarThumbStyle">

                <Setter Property="Template">

                    <Setter.Value>

                        <ControlTemplate TargetType="{x:Type Thumb}">

                            <Border x:Name="ThumbBorder"
                                    CornerRadius="6"
                                    Background="#666"
                                    BorderBrush="#444"
                                    BorderThickness="1" />

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="ThumbBorder"
                                            Property="Background"
                                            Value="#888" />
                                </Trigger>

                                <Trigger Property="IsDragging"
                                         Value="True">
                                    <Setter TargetName="ThumbBorder"
                                            Property="Background"
                                            Value="#eee" />
                                    <Setter TargetName="ThumbBorder"
                                            Property="BorderBrush"
                                            Value="#666" />
                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>

                    </Setter.Value>

                </Setter>

            </Style>

            <!-- ScrollBar (Vertical) -->

            <ControlTemplate TargetType="{x:Type ScrollBar}"
                             x:Key="VerticalScrollBarTemplate">

                <Grid Background="Transparent"
                      Width="{TemplateBinding Width}">

                    <Track x:Name="PART_Track"
                           IsDirectionReversed="True">

                        <Track.DecreaseRepeatButton>

                            <RepeatButton Command="ScrollBar.LineUpCommand"
                                          Focusable="False"
                                          Height="0"
                                          Background="Transparent" />

                        </Track.DecreaseRepeatButton>

                        <Track.Thumb>
                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                        </Track.Thumb>

                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.LineDownCommand"
                                          Focusable="False"
                                          Height="0"
                                          Background="Transparent" />
                        </Track.IncreaseRepeatButton>

                    </Track>

                </Grid>

            </ControlTemplate>

            <!-- ScrollBar (Horizontal) -->

            <ControlTemplate x:Key="HorizontalScrollBarTemplate"
                             TargetType="{x:Type ScrollBar}">

                <Grid Background="Transparent"
                      Height="{TemplateBinding Height}">

                    <Track x:Name="PART_Track">

                        <Track.DecreaseRepeatButton>

                            <RepeatButton Command="ScrollBar.LineLeftCommand"
                                          Focusable="False"
                                          Width="0"
                                          Background="Transparent" />

                        </Track.DecreaseRepeatButton>

                        <Track.Thumb>
                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                        </Track.Thumb>

                        <Track.IncreaseRepeatButton>

                            <RepeatButton Command="ScrollBar.LineRightCommand"
                                          Focusable="False"
                                          Width="0"
                                          Background="Transparent" />

                        </Track.IncreaseRepeatButton>

                    </Track>

                </Grid>

            </ControlTemplate>

            <!-- Scrollbar -->

            <Style TargetType="{x:Type ScrollBar}">

                <Setter Property="Width"
                        Value="12" />
                <Setter Property="Template"
                        Value="{StaticResource VerticalScrollBarTemplate}" />

                <Style.Triggers>

                    <Trigger Property="Orientation"
                             Value="Horizontal">
                        <Setter Property="Height"
                                Value="12" />
                        <Setter Property="Width"
                                Value="Auto" />
                        <Setter Property="Template"
                                Value="{StaticResource HorizontalScrollBarTemplate}" />
                    </Trigger>

                </Style.Triggers>

            </Style>

        </ResourceDictionary>

    </Application.Resources>

</Application>
