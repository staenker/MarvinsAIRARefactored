<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaComboBox"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TextBlock"
                       Grid.Column="0"
                       Text="{Binding Label, ElementName=Root, FallbackValue='Steering Device'}"
                       TextTrimming="CharacterEllipsis"
                       PreviewMouseRightButtonDown="TextBlock_PreviewMouseRightButtonDown">

                <TextBlock.Style>

                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource MairaTextBlockStyle}">

                        <Setter Property="Visibility"
                                Value="Visible" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding Label, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <Button x:Name="HelpButton"
                    Grid.Column="1"
                    Style="{StaticResource HelpIconCommandMixin}"
                    CommandParameter="{Binding HelpTopic, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Visibility="{Binding IsMouseOver, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />

        </Grid>

        <ComboBox x:Name="ComboBox"
                  Grid.Row="1"
                  DisplayMemberPath="Value"
                  SelectedValuePath="Key"
                  ItemsSource="{Binding ItemsSource, ElementName=Root}"
                  SelectedValue="{Binding SelectedValue, ElementName=Root}"
                  IsEditable="False" />

    </Grid>

</UserControl>
