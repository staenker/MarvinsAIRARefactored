<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaStatusBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">

    <Border x:Name="Status_Border"
            BorderThickness="2"
            CornerRadius="8"
            Padding="10,1">

        <Border.Style>

            <Style TargetType="Border">

                <Setter Property="BorderBrush"
                        Value="#666" />

                <Style.Triggers>

                    <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                 Value="Warning">
                        <Setter Property="BorderBrush"
                                Value="#997330" />
                    </DataTrigger>

                    <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                 Value="Error">
                        <Setter Property="BorderBrush"
                                Value="#993030" />
                    </DataTrigger>

                </Style.Triggers>

            </Style>

        </Border.Style>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="Status_TextBlock_1"
                       Grid.Column="0"
                       Text="{Binding StatusText1, ElementName=Root, FallbackValue='Mazda MX-5 Cup'}">

                <TextBlock.Style>

                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource MairaTextBlockStyle}">

                        <Setter Property="Foreground"
                                Value="#eee" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="Foreground"
                                        Value="#ffb22e" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="Foreground"
                                        Value="#ff2e2e" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <Border x:Name="Status_Divider_1"
                    Grid.Column="1"
                    BorderThickness="1,0,0,0"
                    Margin="8,1"
                    VerticalAlignment="Stretch"
                    Opacity="0.5">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="BorderBrush"
                                Value="#666666" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText2, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="BorderBrush"
                                        Value="#997330" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="BorderBrush"
                                        Value="#993030" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

            </Border>

            <TextBlock x:Name="Status_TextBlock_2"
                       Grid.Column="2"
                       Text="{Binding StatusText2, ElementName=Root, FallbackValue='Virginia International Raceway'}">

                <TextBlock.Style>

                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource MairaTextBlockStyle}">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="Foreground"
                                Value="#eeeeee" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText2, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="Foreground"
                                        Value="#ffb22e" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="Foreground"
                                        Value="#ff2e2e" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <Border x:Name="Status_Divider_2"
                    Grid.Column="3"
                    BorderThickness="1,0,0,0"
                    Margin="8,1"
                    VerticalAlignment="Stretch"
                    Opacity="0.5">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="BorderBrush"
                                Value="#666666" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText3, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="BorderBrush"
                                        Value="#997330" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="BorderBrush"
                                        Value="#993030" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

            </Border>

            <TextBlock x:Name="Status_TextBlock_3"
                       Grid.Column="4"
                       Text="{Binding StatusText3, ElementName=Root, FallbackValue='Grand Course'}">

                <TextBlock.Style>

                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource MairaTextBlockStyle}">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="Foreground"
                                Value="#eeeeee" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText3, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="Foreground"
                                        Value="#ffb22e" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="Foreground"
                                        Value="#ff2e2e" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <Border x:Name="Status_Divider_3"
                    Grid.Column="5"
                    BorderThickness="1,0,0,0"
                    Margin="8,1"
                    VerticalAlignment="Stretch"
                    Opacity="0.5">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="BorderBrush"
                                Value="#666666" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText4, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="BorderBrush"
                                        Value="#997330" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="BorderBrush"
                                        Value="#993030" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

            </Border>

            <TextBlock x:Name="Status_TextBlock_4"
                       Grid.Column="6"
                       Text="{Binding StatusText4, ElementName=Root, FallbackValue='Dry'}">

                <TextBlock.Style>

                    <Style TargetType="TextBlock"
                           BasedOn="{StaticResource MairaTextBlockStyle}">

                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="Foreground"
                                Value="#eeeeee" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding StatusText4, ElementName=Root}"
                                         Value="">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Warning">
                                <Setter Property="Foreground"
                                        Value="#ffb22e" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding StatusStyle, ElementName=Root}"
                                         Value="Error">
                                <Setter Property="Foreground"
                                        Value="#ff2e2e" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

        </Grid>

    </Border>

</UserControl>
