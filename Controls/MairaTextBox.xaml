<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaTextBox"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:classes="clr-namespace:MarvinsAIRARefactored.Classes"
             mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TextBlock"
                   Grid.Row="0"
                   Text="{Binding Label, ElementName=Root, FallbackValue='Chatterbox Server Base URL'}">

            <TextBlock.Style>

                <Style TargetType="TextBlock"
                       BasedOn="{StaticResource MairaTextBlockStyle}">

                    <Setter Property="Visibility"
                            Value="Visible" />

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding Label, ElementName=Root}"
                                     Value="">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </TextBlock.Style>

        </TextBlock>

        <TextBox x:Name="TextBox"
                 Grid.Row="1"
                 FontSize="30"
                 Foreground="#ff5b2e"
                 Background="Transparent"
                 CaretBrush="#ff5b2e"
                 BorderBrush="#444"
                 BorderThickness="0,0,0,2"
                 FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow"
                 Text="{Binding Value, ElementName=Root, FallbackValue='Some example text for the text box user control'}"
                 classes:TextBoxBehaviors.IsNumericOnly="{Binding IsNumericOnly, ElementName=Root}" />

    </Grid>

</UserControl>
