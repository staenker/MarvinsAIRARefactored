<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaButtonMapping"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:components="clr-namespace:MarvinsAIRARefactored.Components"
             mc:Ignorable="d"
             Width="600">

    <Border Padding="20"
            BorderThickness="2"
            CornerRadius="5"
            BorderBrush="#666"
            Margin="0,10,0,0">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <controls:MairaButton Grid.Column="0"
                                  x:Name="Record_MairaButton"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/record-white.png"
                                  BlinkIcon="/MarvinsAIRARefactored;component/Artwork/Buttons/record-orange.png"
                                  Click="Record_MairaButton_Click" />

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center">

                <TextBlock x:Name="FirstButton_Label"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Line 1"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="SecondButton_Label"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Line 2"
                           HorizontalAlignment="Center" />

            </StackPanel>

            <controls:MairaButton Grid.Column="4"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/clear.png"
                                  Click="Trash_MairaButton_Click" />

        </Grid>

    </Border>

</UserControl>
