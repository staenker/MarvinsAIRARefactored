<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaButton"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">

    <Grid VerticalAlignment="Center">

        <Grid.Style>

            <Style TargetType="Grid">

                <Setter Property="HorizontalAlignment"
                        Value="Center" />

                <Style.Triggers>

                    <DataTrigger Binding="{Binding LabelOnRight, ElementName=Root}"
                                 Value="True">
                        <Setter Property="HorizontalAlignment"
                                Value="Left" />
                    </DataTrigger>

                </Style.Triggers>

            </Style>

        </Grid.Style>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="TextBlock"
                   Text="{Binding Label, ElementName=Root, FallbackValue=Label}"
                   TextTrimming="CharacterEllipsis">

            <TextBlock.Style>

                <Style TargetType="TextBlock"
                       BasedOn="{StaticResource MairaTextBlockStyle}">

                    <Setter Property="Visibility"
                            Value="Visible" />
                    <Setter Property="Grid.Row"
                            Value="0" />
                    <Setter Property="Grid.Column"
                            Value="0" />
                    <Setter Property="HorizontalAlignment"
                            Value="Center" />
                    <Setter Property="Margin"
                            Value="0,0,0,2" />

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding Label, ElementName=Root}"
                                     Value="">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding LabelOnRight, ElementName=Root}"
                                     Value="True">
                            <Setter Property="Grid.Row"
                                    Value="1" />
                            <Setter Property="Grid.Column"
                                    Value="1" />
                            <Setter Property="Margin"
                                    Value="10,0,0,0" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Left" />
                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </TextBlock.Style>

        </TextBlock>

        <Button x:Name="Button"
                Grid.Row="1"
                Grid.Column="0"
                Focusable="False"
                IsTabStop="False"
                Background="Transparent"
                BorderThickness="0"
                Click="Button_Click">

            <Button.Style>

                <Style TargetType="Button">

                    <Setter Property="OverridesDefaultStyle"
                            Value="True" />
                    <Setter Property="Cursor"
                            Value="Hand" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEnabled, ElementName=Root}"
                                     Value="False">
                            <Setter Property="Cursor"
                                    Value="Arrow" />
                        </DataTrigger>
                    </Style.Triggers>

                </Style>

            </Button.Style>

            <Grid>

                <Grid.Style>

                    <Style TargetType="Grid">

                        <Setter Property="Width"
                                Value="{Binding IconWidth, ElementName=Root}" />
                        <Setter Property="Height"
                                Value="{Binding IconHeight, ElementName=Root}" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                         Value="True">
                                <Setter Property="Width"
                                        Value="32" />
                                <Setter Property="Height"
                                        Value="32" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Grid.Style>

                <!-- Disabled -->

                <Image RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Source"
                                    Value="{Binding DefaultFrame, ElementName=Root}" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />
                            <Setter Property="Visibility"
                                    Value="Hidden" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="/MarvinsAIRARefactored;component/Artwork/Buttons/ring-small-default.png" />
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsEnabled, ElementName=Root}"
                                             Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

                <!-- Pressed -->

                <Image RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Source"
                                    Value="{Binding PressedFrame, ElementName=Root}" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />
                            <Setter Property="Visibility"
                                    Value="Hidden" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="/MarvinsAIRARefactored;component/Artwork/Buttons/ring-small-pressed.png" />
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEnabled, ElementName=Root}"
                                                   Value="True" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Button}"
                                                   Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </MultiDataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEnabled, ElementName=Root}"
                                                   Value="True" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Root}"
                                                   Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </MultiDataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

                <!-- Mapped -->

                <Image RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Source"
                                    Value="{Binding MappedFrame, ElementName=Root}" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />
                            <Setter Property="Visibility"
                                    Value="Hidden" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="/MarvinsAIRARefactored;component/Artwork/Buttons/ring-small-mapped.png" />
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEnabled, ElementName=Root}"
                                                   Value="True" />
                                        <Condition Binding="{Binding IsMapped, ElementName=Root}"
                                                   Value="True" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Root}"
                                                   Value="False" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Button}"
                                                   Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </MultiDataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

                <!-- Default -->

                <Image RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Source"
                                    Value="{Binding DefaultFrame, ElementName=Root}" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />
                            <Setter Property="Visibility"
                                    Value="Hidden" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="/MarvinsAIRARefactored;component/Artwork/Buttons/ring-small-default.png" />
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEnabled, ElementName=Root}"
                                                   Value="True" />
                                        <Condition Binding="{Binding IsMapped, ElementName=Root}"
                                                   Value="False" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Root}"
                                                   Value="False" />
                                        <Condition Binding="{Binding IsPressed, ElementName=Button}"
                                                   Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </MultiDataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

                <!-- Icon -->

                <Image x:Name="Icon_Image"
                       Source="{Binding Icon, ElementName=Root}"
                       RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Opacity"
                                    Value="1" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsEnabled, ElementName=Root}"
                                             Value="False">
                                    <Setter Property="Opacity"
                                            Value="0.25" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

                <!-- Blink Icon -->

                <Image x:Name="Blink_Image"
                       Source="{Binding BlinkIcon, ElementName=Root}"
                       Width="{Binding IconWidth, ElementName=Root}"
                       Height="{Binding IconHeight, ElementName=Root}"
                       RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Visibility"
                                    Value="Visible" />
                            <Setter Property="Width"
                                    Value="{Binding IconWidth, ElementName=Root}" />
                            <Setter Property="Height"
                                    Value="{Binding IconHeight, ElementName=Root}" />

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsBlinking, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsSmall, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Width"
                                            Value="32" />
                                    <Setter Property="Height"
                                            Value="32" />
                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

            </Grid>

        </Button>

    </Grid>

</UserControl>
