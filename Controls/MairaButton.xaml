<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">

    <Grid>

        <Grid.Style>

            <Style TargetType="Grid">

                <Setter Property="HorizontalAlignment" Value="Center"/>

                <Style.Triggers>

                    <DataTrigger Binding="{Binding TitleOnRight, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                    </DataTrigger>

                </Style.Triggers>

            </Style>

        </Grid.Style>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Label x:Name="Label" Content="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Label.Style>

                <Style TargetType="Label">

                    <Setter Property="Visibility" Value="Visible"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="Grid.Row" Value="0"/>
                    <Setter Property="Grid.Column" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding TitleOnRight, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Grid.Row" Value="1"/>
                            <Setter Property="Grid.Column" Value="1"/>
                            <Setter Property="Margin" Value="5,0,0,0"/>
                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </Label.Style>

        </Label>

        <Button Grid.Row="1" Grid.Column="0" x:Name="Button" Focusable="False" IsTabStop="False" Background="Transparent" BorderThickness="0" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp">

            <Button.Style>

                <Style TargetType="Button">

                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Cursor" Value="Hand"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Disabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Cursor" Value="Arrow"/>
                        </DataTrigger>
                    </Style.Triggers>

                </Style>

            </Button.Style>

            <Grid>

                <Image x:Name="ButtonFace_Default_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_default.png" Width="48" Height="48"/>
                <Image x:Name="ButtonFace_Disabled_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_disabled.png" Width="48" Height="48" Visibility="Hidden"/>
                <Image x:Name="ButtonFace_Hover_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_hover.png" Width="48" Height="48" Visibility="Hidden"/>
                <Image x:Name="ButtonFace_Pressed_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_pressed.png" Width="48" Height="48" Visibility="Hidden"/>

                <Image x:Name="ButtonBorder_Default_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_border_default.png" Width="48" Height="48"/>
                <Image x:Name="ButtonBorder_Mapped_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_border_mapped.png" Width="48" Height="48" Visibility="Hidden"/>

                <Image x:Name="BehindIcon_Image" Source="{Binding BehindIcon, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality"/>
                <Image x:Name="ButtonIcon_Image" Source="{Binding ButtonIcon, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality">

                    <Image.Style>

                        <Style TargetType="Image">

                            <Setter Property="Opacity" Value="1.0"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Disabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                            </Style.Triggers>

                        </Style>

                    </Image.Style>

                </Image>

            </Grid>

        </Button>

    </Grid>

</UserControl>
